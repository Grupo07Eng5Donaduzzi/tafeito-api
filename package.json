{
  "name": "tafeito-monorepo",
  "private": true,
  "scripts": {
    "start:main": "cd services/main && npm run start:dev",
    "start:payment": "cd services/payment && npm run start:dev",
    "start:chat": "cd services/chat && npm run start:dev",
    "build:main": "cd services/main && npm run build",
    "build:payment": "cd services/payment && npm run build",
    "build:chat": "cd services/chat && npm run build",
    "install:all": "cd services/main && npm install && cd ../payment && npm install && cd ../chat && npm install",
    "typecheck": "tsc --build --force",
    "check": "biome check .",
    "lint": "biome lint .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.3"
  }
}
