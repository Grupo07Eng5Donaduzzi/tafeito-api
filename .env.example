# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/tafeito

# jwt
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=1h
JWT_ISSUER=tafeito-api
JWT_AUDIENCE=tafeito-clients

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email@iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-firebase-private-key-here\n-----END PRIVATE KEY-----\n"
FIREBASE_API_KEY=your-firebase-api-key

# Security
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
