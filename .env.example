# ─── Banco de Dados ───────────────────────────────────────────────────────────
DATABASE_URL=postgres://tafeito:tafeito_pass@localhost:5432/tafeito

# Usadas pelo docker-compose para criar o container do PostgreSQL
POSTGRES_USER=tafeito
POSTGRES_PASSWORD=tafeito_pass
POSTGRES_DB=tafeito

# ─── Aplicação ────────────────────────────────────────────────────────────────
PORT=3000
JWT_SECRET=troque_por_uma_chave_segura_e_longa

# ─── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=seu-projeto-firebase
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@seu-projeto-firebase.iam.gserviceaccount.com
# A chave privada deve ter as quebras de linha escapadas como \n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"
FIREBASE_API_KEY=sua-api-key-do-firebase
