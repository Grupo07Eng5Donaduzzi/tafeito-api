            },
            "url": {
              "raw": "{{baseUrl}}/reviews/a1b2c3d4-e5f6-7890-abcd-ef1234567890",
              "host": ["{{baseUrl}}"],
              "path": ["reviews", "a1b2c3d4-e5f6-7890-abcd-ef1234567890"]
            }
          }
        },
        {
          "name": "Get Review by Proposal",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/reviews/proposals/d4e5f6a7-b8c9-0123-def0-234567890123",
              "host": ["{{baseUrl}}"],
              "path": ["reviews", "proposals", "d4e5f6a7-b8c9-0123-def0-234567890123"]
            }
          }
        },
        {
          "name": "Get Reviews by Provider",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/reviews/provider/b2c3d4e5-f6a7-8901-bcde-f12345678901?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["reviews", "provider", "b2c3d4e5-f6a7-8901-bcde-f12345678901"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Provider Rating Summary",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/reviews/provider/b2c3d4e5-f6a7-8901-bcde-f12345678901/summary",
              "host": ["{{baseUrl}}"],
              "path": ["reviews", "provider", "b2c3d4e5-f6a7-8901-bcde-f12345678901", "summary"]
            }
          }
        }
      ]
    }
  ]
}
