{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../..",
    "strictPropertyInitialization": false,
    "paths": {
      "@shared/infra/guards/require-provider.guard": ["./src/shared/infra/guards/require-provider.guard"],
      "@shared/*": ["../../shared/src/*"],
      "@users/*": ["./src/modules/users/*"],
      "@reviews/*": ["./src/modules/reviews/*"]
    }
  },
  "include": ["src/**/*.ts", "../../shared/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
