    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/websockets": "^11.1.19",
    "amqplib": "^1.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "drizzle-orm": "^0.45.2",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.20.0",
